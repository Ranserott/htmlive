# Configuración de entorno - Live Code Classroom

# ===========================================
# BACKEND CONFIGURATION
# ===========================================

# Puerto del servidor backend (default: 3001)
PORT=3001

# URL del frontend para CORS (cambiar en producción)
FRONTEND_URL=http://localhost:3000

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================

# URL del servidor WebSocket (cambiar en producción)
SOCKET_URL=http://localhost:3001

# ===========================================
# DOCKER / PRODUCCIÓN
# ===========================================

# Estas variables se usan en docker-compose.yml
# Descomenta y modifica para producción:

# FRONTEND_URL=https://tudominio.com
# SOCKET_URL=https://api.tudominio.com
